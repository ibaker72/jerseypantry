NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=My Corner Store
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Set to true to enable Stripe Tax automatic tax calculation
STRIPE_TAX_ENABLED=false
STRIPE_B2B_STARTER_PRICE_ID=price_
STRIPE_B2B_STANDARD_PRICE_ID=price_
STRIPE_B2B_PREMIUM_PRICE_ID=price_
# Plan amounts in cents — used by net30 invoicing path
STRIPE_B2B_STARTER_AMOUNT_CENTS=9900
STRIPE_B2B_STANDARD_AMOUNT_CENTS=19900
STRIPE_B2B_PREMIUM_AMOUNT_CENTS=39900
RESEND_API_KEY=
# Sender address verified in Resend dashboard
RESEND_FROM_EMAIL=orders@mycornerstore.com
ORDER_NOTIFICATION_EMAIL=
# Agent API — generate with: openssl rand -hex 32
AGENT_API_KEY=
# OpenClaw outbound webhook URL (your OpenClaw instance)
OPENCLAW_WEBHOOK_URL=
# Shared secret for /api/cron/* endpoints
CRON_SECRET=

# ── OpenClaw ──────────────────────────────────────────────────────────────────
# Telegram: create a bot via @BotFather, message the bot once, then call
# https://api.telegram.org/bot<TOKEN>/getUpdates to get your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Places API — used by OpenClaw prospect sweep to find NJ businesses
# Enable "Places API" in Google Cloud Console → APIs & Services
GOOGLE_MAPS_API_KEY=

# Hunter.io — email finder + verifier for B2B prospect sweep
# Free tier: 25 searches/month. Paid plans start at $49/mo.
# https://hunter.io/api-keys
HUNTER_API_KEY=

# ── DoorDash Drive ───────────────────────────────────────────────────────────
# Generate credentials at https://developer.doordash.com/portal
DOORDASH_DEVELOPER_ID=
DOORDASH_KEY_ID=
DOORDASH_SIGNING_SECRET=
DOORDASH_BASE_URL=https://openapi.doordash.com/drive/v2
# Shared secret used to verify inbound webhooks (HMAC SHA256)
DOORDASH_WEBHOOK_SECRET=

# Pickup origin for DoorDash deliveries
STORE_PICKUP_NAME=My Corner Store
STORE_PICKUP_ADDRESS=
STORE_PICKUP_PHONE=
STORE_PICKUP_INSTRUCTIONS=
